<UserControl x:Class="CCZen.App.Controls.DeleteConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
    <Grid>
        <Border Background="#80000000" />
        <Border Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="24,20"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="380" MaxWidth="520">
            <StackPanel>
                <TextBlock x:Name="TitleText" FontSize="15" FontWeight="SemiBold"
                           FontFamily="Microsoft YaHei"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="0,0,0,12" />
                <TextBlock x:Name="MessageText" FontSize="13"
                           FontFamily="Microsoft YaHei"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,16" />
                <CheckBox x:Name="QuarantineCheckBox" Content="移入隔离区（可撤销，推荐）"
                          FontFamily="Microsoft YaHei" FontSize="13"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          IsChecked="True" Margin="0,0,0,8" />
                <TextBlock Text="取消勾选将直接永久删除，不可恢复。"
                           Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,0,0,20" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Margin="0,0,10,0" Click="OnCancelClick" />
                    <Button Content="确定" Style="{StaticResource AccentButton}" Click="OnConfirmClick" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
