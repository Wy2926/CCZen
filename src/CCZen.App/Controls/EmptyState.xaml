<UserControl x:Class="CCZen.App.Controls.EmptyState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
        <TextBlock x:Name="IconText" FontSize="32" HorizontalAlignment="Center"
                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,12" />
        <TextBlock x:Name="MessageText" FontSize="13" FontFamily="Microsoft YaHei"
                   Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
        <Button x:Name="ActionBtn" Margin="0,12,0,0" HorizontalAlignment="Center"
                Visibility="Collapsed" />
    </StackPanel>
</UserControl>
