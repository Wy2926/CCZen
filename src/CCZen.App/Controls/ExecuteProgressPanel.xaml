<UserControl x:Class="CCZen.App.Controls.ExecuteProgressPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <StackPanel Visibility="{Binding IsExecutingBatch, Converter={StaticResource BoolToVis}}" Margin="0,0,0,12">
        <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="6" />
        <TextBlock Text="{Binding ProgressPhase}" Style="{StaticResource SecondaryText}" Margin="0,6,0,8" />
        <TextBlock Text="逐项进度" Style="{StaticResource PrimaryText}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
        <Border Style="{StaticResource ContentBorder}" MaxHeight="220">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ExecuteProgressItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding StatusText}" Style="{StaticResource SecondaryText}"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Path}" Style="{StaticResource DataText}"
                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}" />
                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource SecondaryText}" FontSize="11"
                                                   Margin="0,2,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </StackPanel>
</UserControl>
