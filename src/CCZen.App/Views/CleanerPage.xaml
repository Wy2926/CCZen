<Page
    x:Class="CCZen.App.Views.CleanerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CCZen.App.Models">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="0" MaxWidth="1100">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="智能清理" Style="{StaticResource PageTitleStyle}" />
            <TextBlock
                Text="本地规则引擎（发现 → 证据 → 评分 → 分级）生成清理推荐；T0/T1 可一键移入隔离区，随时撤销。"
                Style="{StaticResource PageDescriptionStyle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{x:Bind ViewModel.RecommendCommand}" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE721;" FontSize="16" />
                            <TextBlock Text="扫描推荐" />
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.CleanCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEA99;" FontSize="16" />
                            <TextBlock Text="一键清理（T0/T1 → 隔离区）" />
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.UndoCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7A7;" FontSize="16" />
                            <TextBlock Text="撤销上一批次" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Spacing="6" Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}">
                    <ProgressBar Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}" Maximum="100" />
                    <TextBlock
                        Text="{x:Bind ViewModel.ProgressPhase, Mode=OneWay}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <InfoBar
            Grid.Row="2"
            Margin="0,12,0,0"
            IsOpen="{x:Bind ViewModel.HasStatus, Mode=OneWay}"
            Message="{x:Bind ViewModel.Status, Mode=OneWay}"
            Severity="Informational"
            IsClosable="False" />

        <TextBlock
            Grid.Row="3"
            Margin="1,16,0,8"
            Text="{x:Bind ViewModel.Summary, Mode=OneWay}"
            Style="{StaticResource BodyStrongTextBlockStyle}" />

        <StackPanel
            Grid.Row="4"
            Spacing="8"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Visibility="{x:Bind IsEmptyStateVisible(ViewModel.HasScanned, ViewModel.IsBusy), Mode=OneWay}">
            <FontIcon Glyph="&#xEA99;" FontSize="36" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
            <TextBlock
                Text="尚未扫描 — 点击「扫描推荐」开始分析本机可清理空间"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ListView
            Grid.Row="4"
            ItemsSource="{x:Bind ViewModel.Groups}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:RecommendationGroup">
                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,2">
                        <Expander.Header>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Background="{x:Bind models:TierVisuals.Badge(Tier)}"
                                    CornerRadius="4"
                                    Padding="8,2"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left">
                                    <TextBlock
                                        Text="{x:Bind models:TierVisuals.Label(Tier)}"
                                        Foreground="{x:Bind models:TierVisuals.BadgeText(Tier)}"
                                        Style="{StaticResource CaptionTextBlockStyle}" />
                                </Border>
                                <TextBlock Grid.Column="1" Text="{x:Bind RuleId}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Text="{x:Bind Detail}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </Expander.Header>
                        <ItemsControl ItemsSource="{x:Bind Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:RecommendationRow">
                                    <Grid ColumnSpacing="12" Padding="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind Size}" HorizontalAlignment="Right" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{x:Bind Path}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Text="{x:Bind Explain}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                FontSize="12"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
