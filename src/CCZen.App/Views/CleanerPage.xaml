<UserControl x:Class="CCZen.App.Views.CleanerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CCZen.App.Controls"
             xmlns:engine="clr-namespace:CCZen.Engine.Rules;assembly=CCZen.Engine">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="智能清理" Style="{StaticResource PageTitle}" />
            <TextBlock Text="规则引擎扫描并推荐可清理项：T0/T1 默认勾选，T2 需手动勾选确认，T3 仅提示。所有清理默认移入隔离区，可整批撤销。"
                       Style="{StaticResource SecondaryText}" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarBorder}" Margin="0,0,0,12">
            <DockPanel>
                <Button DockPanel.Dock="Left" Content="🔍 扫描推荐" Style="{StaticResource AccentButton}"
                        Command="{Binding RecommendCommand}" />
                <TextBlock DockPanel.Dock="Right" Text="{Binding Summary}" Style="{StaticResource SecondaryText}"
                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                <Border />
            </DockPanel>
        </Border>

        <!-- Progress -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="6" />
            <TextBlock Text="{Binding ProgressPhase}" Style="{StaticResource SecondaryText}" Margin="0,6,0,0" />
        </StackPanel>

        <!-- Groups -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <Grid>
                <controls:EmptyState Icon="🧹" Message="尚未扫描 — 点击「扫描推荐」开始">
                    <controls:EmptyState.Style>
                        <Style TargetType="controls:EmptyState">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasScanned}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:EmptyState.Style>
                </controls:EmptyState>

                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="14,10">
                                <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                    <Expander.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsThreeState="True" VerticalAlignment="Center"
                                                      IsChecked="{Binding GroupChecked, Mode=TwoWay}"
                                                      IsEnabled="{Binding HasSelectableItems}" Margin="0,0,10,0" />
                                            <controls:TierBadge Grid.Column="1" Tier="{Binding Tier}" Margin="0,0,10,0" />
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource PrimaryText}" FontSize="13" />
                                                <TextBlock Text="{Binding RuleId}" Style="{StaticResource SecondaryText}" FontSize="11"
                                                           FontFamily="Cascadia Code,Consolas" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Text="{Binding Detail}" Style="{StaticResource DataText}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"
                                                       Margin="12,0" />
                                        </Grid>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding Items}" Margin="26,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              IsEnabled="{Binding IsSelectable}" Margin="0,0,10,0" />
                                                    <TextBlock Grid.Column="1" Text="{Binding SizeText}" Style="{StaticResource DataText}"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Path}" Style="{StaticResource DataText}"
                                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}" />
                                                        <TextBlock Text="{Binding Explain}" Style="{StaticResource SecondaryText}"
                                                                   FontSize="11" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- Selection summary bar -->
        <Border Grid.Row="4" Style="{StaticResource ToolbarBorder}" Margin="0,12,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="↩ 撤销上次" Command="{Binding UndoCommand}" Margin="0,0,10,0" />
                    <Button Content="🧹 清理所选（移入隔离区）" Style="{StaticResource AccentButton}"
                            Command="{Binding CleanSelectedCommand}" />
                </StackPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectionSummary}" Style="{StaticResource PrimaryText}" />
                    <TextBlock Text="{Binding Status}" Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,2,0,0"
                               Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
