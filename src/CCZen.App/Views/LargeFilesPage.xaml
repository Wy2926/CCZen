<UserControl x:Class="CCZen.App.Views.LargeFilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CCZen.App.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="大文件搜索" Style="{StaticResource PageTitle}" />
            <TextBlock Text="{Binding IndexStatus}" Style="{StaticResource SecondaryText}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Search toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarBorder}" Margin="0,0,0,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="🔍 搜索" Style="{StaticResource AccentButton}"
                        Command="{Binding SearchCommand}" Margin="10,0,0,0" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="类型" Style="{StaticResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox SelectedIndex="{Binding KindIndex, Mode=TwoWay}" MinWidth="110" Margin="0,0,16,0">
                        <ComboBoxItem Content="全部" />
                        <ComboBoxItem Content="仅文件" />
                        <ComboBoxItem Content="仅目录" />
                    </ComboBox>
                    <TextBlock Text="最小大小 (MB)" Style="{StaticResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Text="{Binding MinSizeMb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="0,0,16,0" />
                    <TextBlock Text="名称包含" Style="{StaticResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Text="{Binding NameFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="160" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Progress -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <StackPanel Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="6" />
                <TextBlock Text="{Binding ProgressPhase}" Style="{StaticResource SecondaryText}" Margin="0,6,0,0" />
            </StackPanel>
            <controls:ExecuteProgressPanel DataContext="{Binding}" />
        </StackPanel>

        <!-- Results -->
        <Border Grid.Row="3" Style="{StaticResource ContentBorder}">
            <Grid>
                <controls:EmptyState Icon="🔍" Message="输入条件并点击「搜索」— 首次搜索会自动构建索引">
                    <controls:EmptyState.Style>
                        <Style TargetType="controls:EmptyState">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasStatus}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:EmptyState.Style>
                </controls:EmptyState>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Results}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding Kind}" Style="{StaticResource SecondaryText}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding SizeText}" Style="{StaticResource DataText}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding Path}" Style="{StaticResource DataText}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Path}" />
                                        <TextBlock Grid.Column="4" Text="{Binding Detail}" Style="{StaticResource SecondaryText}"
                                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Selection summary bar -->
        <Border Grid.Row="4" Style="{StaticResource ToolbarBorder}" Margin="0,12,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="🗑 删除所选" Style="{StaticResource AccentButton}"
                        Command="{Binding DeleteSelectedCommand}"
                        ToolTip="删除前可选择移入隔离区或直接永久删除（默认方式见设置）" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectionSummary}" Style="{StaticResource PrimaryText}" />
                    <TextBlock Text="{Binding Status}" Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,2,0,0"
                               Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
