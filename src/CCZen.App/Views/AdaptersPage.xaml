<UserControl x:Class="CCZen.App.Views.AdaptersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" MaxWidth="1100" HorizontalAlignment="Stretch">
            <TextBlock Text="应用适配器" Style="{StaticResource PageTitle}" />
            <TextBlock Text="内置应用适配器规则集（specs/03）：每个适配器声明可清理项及其风险分级，所有智能来自本地规则，无任何云端依赖。"
                       Style="{StaticResource SecondaryText}" Margin="0,4,0,16" TextWrapping="Wrap" />

            <ItemsControl ItemsSource="{Binding Adapters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="14,10">
                            <Expander>
                                <Expander.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource PrimaryText}"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="1" Background="{DynamicResource ControlSubtleBrush}"
                                                CornerRadius="3" Padding="8,2" Margin="10,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CategoryLabel}" Style="{StaticResource SecondaryText}"
                                                       FontSize="11" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Detail}" Style="{StaticResource SecondaryText}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                                    </Grid>
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding Items}" Margin="8,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Tier}" Style="{StaticResource DataText}"
                                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding Explain}" Style="{StaticResource PrimaryText}"
                                                           FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2" Text="{Binding Detail}" Style="{StaticResource SecondaryText}"
                                                           FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
