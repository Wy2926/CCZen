<Page
    x:Class="CCZen.App.Views.AdaptersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CCZen.App.Models">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" MaxWidth="1100" HorizontalAlignment="Stretch">
            <TextBlock Text="应用适配" Style="{StaticResource PageTitleStyle}" />
            <TextBlock
                Text="内置声明式适配器清单（specs/03）：每个应用如何被发现、哪些缓存可清理。适配器只是数据，不执行任何代码；规则包需签名校验后才可加载。"
                Style="{StaticResource PageDescriptionStyle}" />

            <ItemsControl ItemsSource="{x:Bind ViewModel.Adapters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:AdapterRow">
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,2">
                            <Expander.Header>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE71D;" FontSize="16" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind CategoryLabel}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind Detail}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </Expander.Header>
                            <ItemsControl ItemsSource="{x:Bind Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:AdapterItemRow">
                                        <Grid ColumnSpacing="12" Padding="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="96" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border
                                                Background="{x:Bind models:TierVisuals.Badge(Tier)}"
                                                CornerRadius="4"
                                                Padding="8,2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                                <TextBlock
                                                    Text="{x:Bind models:TierVisuals.Label(Tier)}"
                                                    Foreground="{x:Bind models:TierVisuals.BadgeText(Tier)}"
                                                    Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Explain}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind Detail}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
