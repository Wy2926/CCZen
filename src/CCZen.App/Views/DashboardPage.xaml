<UserControl x:Class="CCZen.App.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CCZen.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" MaxWidth="1100" HorizontalAlignment="Stretch">
            <TextBlock Text="总览" Style="{StaticResource PageTitle}" />
            <TextBlock Text="查看磁盘空间占用概况，并快速进入清理与空间分析工具。"
                       Style="{StaticResource SecondaryText}" Margin="0,4,0,16" />

            <controls:SectionHeader Title="快速操作" />
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Tag="cleaner" Click="OnQuickActionClick"
                        HorizontalContentAlignment="Left" Padding="16" MinHeight="96" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="🧹" FontSize="20" Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="智能清理" Style="{StaticResource PrimaryText}" Margin="0,6,0,2" />
                        <TextBlock Text="规则引擎扫描并推荐可清理项" Style="{StaticResource SecondaryText}"
                                   FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Tag="largefiles" Click="OnQuickActionClick"
                        HorizontalContentAlignment="Left" Padding="16" MinHeight="96" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="🔍" FontSize="20" Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="大文件搜索" Style="{StaticResource PrimaryText}" Margin="0,6,0,2" />
                        <TextBlock Text="MFT/USN 秒级索引，按条件定位大文件" Style="{StaticResource SecondaryText}"
                                   FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" Tag="quarantine" Click="OnQuickActionClick"
                        HorizontalContentAlignment="Left" Padding="16" MinHeight="96" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🗃" FontSize="20" Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="隔离区与撤销" Style="{StaticResource PrimaryText}" Margin="0,6,0,2" />
                        <TextBlock Text="所有清理默认可撤销，误删可一键还原" Style="{StaticResource SecondaryText}"
                                   FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
            </Grid>

            <controls:SectionHeader Title="磁盘空间">
                <controls:SectionHeader.Action>
                    <Button Content="刷新" Command="{Binding RefreshCommand}" Padding="12,4" />
                </controls:SectionHeader.Action>
            </controls:SectionHeader>

            <ItemsControl ItemsSource="{Binding Drives}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="💽" FontSize="26" VerticalAlignment="Center" Margin="0,0,16,0" />
                                <StackPanel Grid.Column="1">
                                    <DockPanel Margin="0,0,0,6">
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding FileSystem}"
                                                   Style="{StaticResource SecondaryText}" HorizontalAlignment="Right" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Label}" Style="{StaticResource PrimaryText}" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource SecondaryText}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <ProgressBar Value="{Binding UsedPercent, Mode=OneWay}" Maximum="100" Height="6" />
                                    <TextBlock Text="{Binding Detail}" Style="{StaticResource SecondaryText}"
                                               FontSize="11" Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
