<Page
    x:Class="CCZen.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CCZen.App.Models">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" MaxWidth="1100" HorizontalAlignment="Stretch">
            <TextBlock Text="仪表盘" Style="{StaticResource PageTitleStyle}" />
            <TextBlock
                Text="查看磁盘空间占用概况，并快速进入清理与空间分析工具。"
                Style="{StaticResource PageDescriptionStyle}" />

            <TextBlock Text="快速操作" Style="{StaticResource SectionHeaderStyle}" />
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Tag="cleaner"
                    Click="OnQuickActionClick"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Padding="16"
                    MinHeight="96">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xEA99;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left" />
                        <TextBlock Text="智能清理" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock
                            Text="规则引擎扫描并推荐可清理项"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Button>

                <Button
                    Grid.Column="1"
                    Tag="largefiles"
                    Click="OnQuickActionClick"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Padding="16"
                    MinHeight="96">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE721;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left" />
                        <TextBlock Text="大文件搜索" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock
                            Text="MFT/USN 秒级索引，按条件定位大文件"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Button>

                <Button
                    Grid.Column="2"
                    Tag="quarantine"
                    Click="OnQuickActionClick"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Padding="16"
                    MinHeight="96">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE7A7;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left" />
                        <TextBlock Text="隔离区与撤销" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock
                            Text="所有清理默认可撤销，误删可一键还原"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid>
                <TextBlock Text="磁盘空间" Style="{StaticResource SectionHeaderStyle}" />
                <Button
                    Content="刷新"
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom" />
            </Grid>

            <ItemsControl ItemsSource="{x:Bind ViewModel.Drives}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:DriveRow">
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,8">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xEDA2;" FontSize="28" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind Label}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{x:Bind Name}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock
                                            Text="{x:Bind FileSystem}"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                    <ProgressBar Value="{x:Bind UsedPercent}" Maximum="100" />
                                    <TextBlock
                                        Text="{x:Bind Detail}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
