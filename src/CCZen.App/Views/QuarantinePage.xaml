<UserControl x:Class="CCZen.App.Views.QuarantinePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CCZen.App.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="隔离区" Style="{StaticResource PageTitle}" />
            <TextBlock Text="所有清理默认移入隔离区（红线 1：永不静默永久删除）。误删可整批一键还原到原路径。"
                       Style="{StaticResource SecondaryText}" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1">
            <controls:EmptyState Icon="🗃" Message="隔离区为空 — 本次会话执行的清理批次会显示在这里">
                <controls:EmptyState.Style>
                    <Style TargetType="controls:EmptyState">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding BatchHistory.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:EmptyState.Style>
            </controls:EmptyState>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding BatchHistory}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="🗃" FontSize="22" VerticalAlignment="Center" Margin="0,0,14,0" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding BatchId}" Style="{StaticResource DataText}"
                                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                                            <TextBlock Text="{Binding TimeLabel}" Style="{StaticResource SecondaryText}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Summary}" Style="{StaticResource PrimaryText}"
                                                   FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="↩ 整批还原" VerticalAlignment="Center"
                                            Command="{Binding DataContext.RestoreBatchCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding Status}" Style="{StaticResource SecondaryText}" Margin="0,10,0,0"
                   Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}" />
    </Grid>
</UserControl>
