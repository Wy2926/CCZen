<Page
    x:Class="CCZen.App.Views.QuarantinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CCZen.App.Models">

    <Grid Padding="{StaticResource PagePadding}" MaxWidth="1100">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="隔离区与撤销" Style="{StaticResource PageTitleStyle}" />
            <TextBlock
                Text="CCZen 绝不静默永久删除：每次清理生成一个批次并整体移入隔离区，可在此按批次一键还原。"
                Style="{StaticResource PageDescriptionStyle}" />
        </StackPanel>

        <InfoBar
            Grid.Row="1"
            IsOpen="True"
            IsClosable="False"
            Severity="Informational"
            Title="安全模型"
            Message="隔离区按卷存放（specs/04），批次执行恰好一次，还原回原始路径。到期自动清空等策略将在后续版本提供。" />

        <InfoBar
            Grid.Row="2"
            Margin="0,8,0,0"
            IsOpen="{x:Bind ViewModel.HasStatus, Mode=OneWay}"
            Message="{x:Bind ViewModel.Status, Mode=OneWay}"
            Severity="Success"
            IsClosable="False" />

        <StackPanel
            Grid.Row="3"
            Spacing="8"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Visibility="{x:Bind IsEmptyVisible, Mode=OneWay}">
            <FontIcon Glyph="&#xE7A7;" FontSize="36" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
            <TextBlock
                Text="本次会话还没有清理批次 — 在「智能清理」执行一键清理后，批次会出现在这里"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ListView
            Grid.Row="3"
            Margin="0,16,0,0"
            ItemsSource="{x:Bind ViewModel.BatchHistory}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:QuarantineBatchRow">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,4">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xF12B;" FontSize="20" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{x:Bind BatchId}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock
                                    Text="{x:Bind Summary}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock
                                    Text="{x:Bind TimeLabel}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Button
                                Grid.Column="2"
                                Content="还原此批次"
                                Click="OnRestoreClick"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
