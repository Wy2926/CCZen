<UserControl x:Class="CCZen.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CCZen.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" MaxWidth="1100" HorizontalAlignment="Stretch">
            <TextBlock Text="设置" Style="{StaticResource PageTitle}" />
            <TextBlock Text="外观、扫描与清理行为设置。部分选项为占位，将随对应引擎能力落地生效。"
                       Style="{StaticResource SecondaryText}" Margin="0,4,0,16" />

            <controls:SectionHeader Title="外观" />
            <controls:SettingCard Icon="🎨" Header="应用主题" Description="选择深色或浅色主题（即时生效）">
                <controls:SettingCard.ActionContent>
                    <ComboBox SelectedIndex="{Binding ThemeIndex, Mode=TwoWay}" MinWidth="140">
                        <ComboBoxItem Content="深色（默认）" />
                        <ComboBoxItem Content="浅色" />
                    </ComboBox>
                </controls:SettingCard.ActionContent>
            </controls:SettingCard>

            <controls:SectionHeader Title="扫描" />
            <controls:SettingCard Icon="⚡" Header="低优先级 IO" Description="扫描使用低优先级线程与 IO，前台使用无感（SCAN-NFR-003）">
                <controls:SettingCard.ActionContent>
                    <CheckBox IsChecked="{Binding LowPriorityIo, Mode=TwoWay}" />
                </controls:SettingCard.ActionContent>
            </controls:SettingCard>
            <controls:SettingCard Icon="📌" Header="常驻托盘（实验）" Description="常驻进程持续消费 USN 日志，保持索引实时（specs/05 开放问题 D7，暂未生效）">
                <controls:SettingCard.ActionContent>
                    <CheckBox IsChecked="{Binding TrayResident, Mode=TwoWay}" />
                </controls:SettingCard.ActionContent>
            </controls:SettingCard>

            <controls:SectionHeader Title="清理" />
            <controls:SettingCard Icon="✅" Header="清理前确认" Description="执行清理所选前显示批次内容确认对话框">
                <controls:SettingCard.ActionContent>
                    <CheckBox IsChecked="{Binding ConfirmBeforeClean, Mode=TwoWay}" />
                </controls:SettingCard.ActionContent>
            </controls:SettingCard>
            <controls:SettingCard Icon="🕒" Header="隔离区保留时长" Description="超过保留期的批次可被自动清空（specs/04，策略暂未生效）">
                <controls:SettingCard.ActionContent>
                    <ComboBox SelectedIndex="{Binding RetentionIndex, Mode=TwoWay}" MinWidth="140">
                        <ComboBoxItem Content="7 天" />
                        <ComboBoxItem Content="14 天" />
                        <ComboBoxItem Content="30 天" />
                    </ComboBox>
                </controls:SettingCard.ActionContent>
            </controls:SettingCard>

            <controls:SectionHeader Title="隐私" />
            <controls:SettingCard Icon="🛡" Header="遥测" Description="CCZen 默认不收集任何遥测数据，清理智能全部在本地完成">
                <controls:SettingCard.ActionContent>
                    <CheckBox IsChecked="False" IsEnabled="False" />
                </controls:SettingCard.ActionContent>
            </controls:SettingCard>

            <controls:SectionHeader Title="关于" />
            <controls:SettingCard Icon="🧹" Header="CCZen" Description="{Binding Version}">
                <controls:SettingCard.ActionContent>
                    <TextBlock Style="{StaticResource SecondaryText}" VerticalAlignment="Center">
                        <Hyperlink NavigateUri="https://github.com/Wy2926/CCZen" RequestNavigate="OnNavigate"
                                   Foreground="{DynamicResource AccentBrush}">GitHub</Hyperlink>
                        <Run Text="  " />
                        <Hyperlink NavigateUri="https://github.com/Wy2926/CCZen/tree/main/docs/specs" RequestNavigate="OnNavigate"
                                   Foreground="{DynamicResource AccentBrush}">规格文档</Hyperlink>
                    </TextBlock>
                </controls:SettingCard.ActionContent>
            </controls:SettingCard>
        </StackPanel>
    </ScrollViewer>
</UserControl>
