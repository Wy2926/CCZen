<Page
    x:Class="CCZen.App.Views.DuplicatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CCZen.App.Controls">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" MaxWidth="1100" HorizontalAlignment="Stretch" Spacing="4">
            <TextBlock Text="重复文件" Style="{StaticResource PageTitleStyle}" />
            <TextBlock
                Text="按内容哈希查找重复的大文件，保留一份并安全清理其余副本。"
                Style="{StaticResource PageDescriptionStyle}" />

            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="功能规划中"
                Message="重复文件检测在规格中列为开放问题 D8（全量哈希调度：仅手动 vs 空闲自动），将在后续里程碑提供。" />

            <TextBlock Text="规划中的能力" Style="{StaticResource SectionHeaderStyle}" />
            <controls:SettingCard
                Glyph="&#xE8C8;"
                Header="基于索引的候选筛选"
                Description="利用扫描索引先按大小分桶，仅对同大小文件计算哈希，避免全盘读取"
                IsEnabled="False" />
            <controls:SettingCard
                Glyph="&#xE72E;"
                Header="安全清理副本"
                Description="重复副本默认移入隔离区，永不静默永久删除"
                IsEnabled="False" />
        </StackPanel>
    </ScrollViewer>
</Page>
