<UserControl x:Class="CCZen.App.Views.DuplicatesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CCZen.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" MaxWidth="1100" HorizontalAlignment="Stretch">
            <TextBlock Text="重复文件" Style="{StaticResource PageTitle}" />
            <TextBlock Text="按内容哈希查找重复的大文件，保留一份并安全清理其余副本。"
                       Style="{StaticResource SecondaryText}" Margin="0,4,0,16" />

            <Border Background="#1A42A5F5" BorderBrush="{DynamicResource InfoBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="14,10" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ℹ" FontSize="14" Foreground="{DynamicResource InfoBrush}" Margin="0,0,10,0" />
                    <TextBlock Style="{StaticResource PrimaryText}" TextWrapping="Wrap">
                        <Run Text="功能规划中 — " FontWeight="SemiBold" />
                        <Run Text="重复文件检测在规格中列为开放问题 D8（全量哈希调度：仅手动 vs 空闲自动），将在后续里程碑提供。" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <controls:SectionHeader Title="规划中的能力" />
            <controls:SettingCard Icon="🗂" Header="基于索引的候选筛选"
                                  Description="利用扫描索引先按大小分桶，仅对同大小文件计算哈希，避免全盘读取"
                                  IsEnabled="False" />
            <controls:SettingCard Icon="🛡" Header="安全清理副本"
                                  Description="重复副本默认移入隔离区，永不静默永久删除"
                                  IsEnabled="False" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
