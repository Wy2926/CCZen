<Window
    x:Class="CCZen.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CCZen.App.Models"
    Title="CCZen">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
                Content="扫描推荐"
                Command="{x:Bind ViewModel.RecommendCommand}"
                Style="{StaticResource AccentButtonStyle}" />
            <Button
                Content="一键清理 (T0/T1 → 隔离区)"
                Command="{x:Bind ViewModel.CleanCommand}" />
            <Button
                Content="撤销上一批次"
                Command="{x:Bind ViewModel.UndoCommand}" />
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                Width="24"
                Height="24" />
        </StackPanel>

        <TextBlock
            Grid.Row="1"
            Text="{x:Bind ViewModel.Summary, Mode=OneWay}"
            Style="{StaticResource BodyStrongTextBlockStyle}" />

        <ListView
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.Recommendations}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:RecommendationRow">
                    <Grid ColumnSpacing="12" Padding="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind Tier}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{x:Bind Size}" HorizontalAlignment="Right" />
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{x:Bind Path}" TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Text="{x:Bind Explain}"
                                Opacity="0.7"
                                FontSize="12"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock
            Grid.Row="3"
            Text="{x:Bind ViewModel.Status, Mode=OneWay}"
            Opacity="0.7" />
    </Grid>
</Window>
