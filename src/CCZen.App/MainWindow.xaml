<Window x:Class="CCZen.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CCZen.App.Controls"
        Title="CCZen"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="640"
        Background="{DynamicResource PrimaryBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Title bar button style -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button — red on hover -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C50F1F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="-1"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource SidebarBackgroundBrush}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               Text="🧹 CCZen — 智能磁盘清理" VerticalAlignment="Center"
                               Foreground="{DynamicResource AccentBrush}"
                               FontFamily="Microsoft YaHei" FontSize="13"
                               Margin="12,0,0,0" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="OnMinimize" />
                        <Button x:Name="MaxRestoreBtn" Style="{StaticResource CaptionButton}" Content="&#xE922;" Click="OnMaxRestore" />
                        <Button Style="{StaticResource CloseButton}" Content="&#xE8BB;"
                                Foreground="{DynamicResource SecondaryTextBrush}" Click="OnClose" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Sidebar navigation -->
            <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}">
                <StackPanel Margin="0,8,0,0">
                    <RadioButton x:Name="NavHome" Style="{StaticResource NavButton}"
                                 Content="🏠  一键清理" IsChecked="True" Checked="OnNavChecked" Tag="home" />
                    <RadioButton x:Name="NavDashboard" Style="{StaticResource NavButton}"
                                 Content="📊  总览" Checked="OnNavChecked" Tag="dashboard" />
                    <RadioButton x:Name="NavCleaner" Style="{StaticResource NavButton}"
                                 Content="🧰  深度清理" Checked="OnNavChecked" Tag="cleaner" />
                    <RadioButton x:Name="NavLargeFiles" Style="{StaticResource NavButton}"
                                 Content="🔍  大文件搜索" Checked="OnNavChecked" Tag="largefiles" />
                    <RadioButton x:Name="NavDuplicates" Style="{StaticResource NavButton}"
                                 Content="📑  重复文件" Checked="OnNavChecked" Tag="duplicates" />
                    <RadioButton x:Name="NavAdapters" Style="{StaticResource NavButton}"
                                 Content="🧩  应用适配器" Checked="OnNavChecked" Tag="adapters" />
                    <RadioButton x:Name="NavQuarantine" Style="{StaticResource NavButton}"
                                 Content="🗃  隔离区" Checked="OnNavChecked" Tag="quarantine" />
                    <RadioButton x:Name="NavSettings" Style="{StaticResource NavButton}"
                                 Content="⚙  设置" Checked="OnNavChecked" Tag="settings" />
                </StackPanel>
            </Border>

            <!-- Main content -->
            <ContentControl x:Name="ContentHost" Grid.Row="1" Grid.Column="1" />

            <!-- Status bar -->
            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource StatusBarStyle}">
                <DockPanel Margin="12,4">
                    <controls:StatusIndicator x:Name="EngineStatus" DockPanel.Dock="Left"
                                              Label="引擎未连接" Status="Offline" />
                    <TextBlock x:Name="StatusText" DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Style="{StaticResource SecondaryText}" Text="就绪" />
                    <Border />
                </DockPanel>
            </Border>

            <!-- Global dialog overlays -->
            <controls:MessageDialog x:Name="GlobalDialog" Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="2" Panel.ZIndex="100" />
            <controls:DeleteConfirmDialog x:Name="GlobalDeleteDialog" Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="2" Panel.ZIndex="101" />
        </Grid>
    </Border>
</Window>
