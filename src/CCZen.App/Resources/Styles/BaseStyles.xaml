<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="6" />
    </Style>

    <Style x:Key="ToolbarBorder" TargetType="Border" BasedOn="{StaticResource CardBorder}">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Margin" Value="6,0,6,4" />
    </Style>

    <Style x:Key="InfoHeaderBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ControlHeaderBrush}" />
        <Setter Property="Padding" Value="10,6" />
    </Style>

    <Style x:Key="ContentBorder" TargetType="Border" BasedOn="{StaticResource CardBorder}">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="6,2,6,0" />
    </Style>

    <Style x:Key="NavButton" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="Microsoft YaHei" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Border x:Name="Indicator" Width="3" HorizontalAlignment="Left"
                                Background="Transparent" CornerRadius="0,2,2,0" Margin="0,8" />
                        <Border x:Name="Bd" Background="Transparent"
                                Padding="16,0,12,0" Margin="3,0,0,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavActiveBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Microsoft YaHei" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="SecondaryText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="FontFamily" Value="Microsoft YaHei" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="CardTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Microsoft YaHei" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="DataText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="DataLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="FontFamily" Value="Microsoft YaHei" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Width" Value="60" />
    </Style>

    <Style x:Key="StatusBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource StatusBarBrush}" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Microsoft YaHei" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

</ResourceDictionary>
