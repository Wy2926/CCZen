<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- === Semantic Colors === -->
    <Color x:Key="PrimaryBackgroundColor">#F3F3F3</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <Color x:Key="SidebarBackgroundColor">#E8E8EC</Color>
    <Color x:Key="PrimaryTextColor">#1E1E2E</Color>
    <Color x:Key="SecondaryTextColor">#666680</Color>
    <Color x:Key="AccentColor">#0078D4</Color>
    <Color x:Key="SuccessColor">#107C10</Color>
    <Color x:Key="WarningColor">#CA5010</Color>
    <Color x:Key="ErrorColor">#D13438</Color>
    <Color x:Key="InfoColor">#0063B1</Color>
    <Color x:Key="BorderColor">#D0D0D8</Color>
    <Color x:Key="HoverColor">#E0E0E8</Color>
    <Color x:Key="SelectedColor">#CCE4F7</Color>

    <!-- === Interactive State Colors === -->
    <Color x:Key="ControlHoverColor">#E8E8F0</Color>
    <Color x:Key="ControlPressedColor">#D8D8E4</Color>
    <Color x:Key="ControlInputColor">#FAFAFA</Color>
    <Color x:Key="ControlHeaderColor">#ECECF0</Color>
    <Color x:Key="ControlSubtleBorderColor">#B8B8C8</Color>
    <Color x:Key="ControlSubtleColor">#DCDCE4</Color>
    <Color x:Key="ScrollThumbColor">#B0B0C0</Color>
    <Color x:Key="StatusBarColor">#E0E0E8</Color>
    <Color x:Key="NavActiveColor">#DAEAF7</Color>
    <Color x:Key="NavHoverColor">#E4E4EC</Color>
    <Color x:Key="RowAlternateColor">#F8F8FC</Color>
    <Color x:Key="RowHoverColor">#E8E8F4</Color>
    <Color x:Key="RowSelectedColor">#CCE4F7</Color>
    <Color x:Key="TabHoverColor">#E8E8F0</Color>

    <!-- === Brushes === -->
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="{StaticResource PrimaryBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}" />
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="{StaticResource ControlHoverColor}" />
    <SolidColorBrush x:Key="ControlPressedBrush" Color="{StaticResource ControlPressedColor}" />
    <SolidColorBrush x:Key="ControlInputBrush" Color="{StaticResource ControlInputColor}" />
    <SolidColorBrush x:Key="ControlHeaderBrush" Color="{StaticResource ControlHeaderColor}" />
    <SolidColorBrush x:Key="ControlSubtleBorderBrush" Color="{StaticResource ControlSubtleBorderColor}" />
    <SolidColorBrush x:Key="ControlSubtleBrush" Color="{StaticResource ControlSubtleColor}" />
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="{StaticResource ScrollThumbColor}" />
    <SolidColorBrush x:Key="StatusBarBrush" Color="{StaticResource StatusBarColor}" />
    <SolidColorBrush x:Key="NavActiveBrush" Color="{StaticResource NavActiveColor}" />
    <SolidColorBrush x:Key="NavHoverBrush" Color="{StaticResource NavHoverColor}" />
    <SolidColorBrush x:Key="RowAlternateBrush" Color="{StaticResource RowAlternateColor}" />
    <SolidColorBrush x:Key="RowHoverBrush" Color="{StaticResource RowHoverColor}" />
    <SolidColorBrush x:Key="RowSelectedBrush" Color="{StaticResource RowSelectedColor}" />
    <SolidColorBrush x:Key="TabHoverBrush" Color="{StaticResource TabHoverColor}" />

    <!-- === Risk Tier Badges (specs/02: T0 safest → T3 report-only) === -->
    <SolidColorBrush x:Key="Tier0BadgeBrush" Color="#22107C10" />
    <SolidColorBrush x:Key="Tier0TextBrush" Color="#107C10" />
    <SolidColorBrush x:Key="Tier1BadgeBrush" Color="#220063B1" />
    <SolidColorBrush x:Key="Tier1TextBrush" Color="#0063B1" />
    <SolidColorBrush x:Key="Tier2BadgeBrush" Color="#22CA5010" />
    <SolidColorBrush x:Key="Tier2TextBrush" Color="#CA5010" />
    <SolidColorBrush x:Key="Tier3BadgeBrush" Color="#22666680" />
    <SolidColorBrush x:Key="Tier3TextBrush" Color="#666680" />

</ResourceDictionary>
